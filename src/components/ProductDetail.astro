---
import type {
  Product,
  ProductCategory,
  RelatedProductWithReason,
} from "../data/products";

interface Props {
  product: Product;
  categories: ProductCategory[];
  relatedProducts: RelatedProductWithReason[];
}

const { product, categories, relatedProducts } = Astro.props;

const productCategories = product.categories
  .map((categoryId) =>
    categories.find((category) => category.id === categoryId),
  )
  .filter(Boolean);
---

<div class="pdp-wrapper">
  <!-- Product Hero Section -->
  <section class="pdp-hero">
    <div class="container">
      <div class="pdp-image-container">
        {
          product.images.length > 0 ? (
            <img
              src={product.images[0].src}
              alt={product.images[0].alt || `Fotografía de ${product.name}`}
              loading="lazy"
              class="pdp-image"
              id="pdp-current-image"
            />
          ) : (
            <div class="image-fallback" aria-hidden="true" />
          )
        }
        {
          product.images.length > 1 && (
            <>
              <button
                class="pdp-nav-btn pdp-nav-prev"
                id="pdp-prev"
                aria-label="Anterior"
              >
                ‹
              </button>
              <button
                class="pdp-nav-btn pdp-nav-next"
                id="pdp-next"
                aria-label="Siguiente"
              >
                ›
              </button>
            </>
          )
        }
      </div>

      <div class="pdp-info">
        <!-- Product Name -->
        <h1 class="pdp-title">{product.name}</h1>

        <!-- Fiscalizado Badge -->
        {
          product.fiscalizado && (
            <div class="pdp-fiscalizado-badge">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              </svg>
              <span>Producto Fiscalizado</span>
            </div>
          )
        }

        <!-- Short Description -->
        {product.summary && <p class="pdp-summary">{product.summary}</p>}

        <!-- Presentations -->
        {
          product.presentations && product.presentations.length > 0 && (
            <div class="pdp-presentations">
              <label for="pdp-presentations-select" class="pdp-label">
                Presentaciones disponibles
              </label>
              <select
                id="pdp-presentations-select"
                class="pdp-select"
                data-product-select
              >
                {product.presentations.map((presentation) => (
                  <option
                    value={presentation.id}
                    data-label={presentation.label}
                    data-minimum-order={presentation.minimumOrder || ""}
                  >
                    {presentation.label}
                    {presentation.minimumOrder &&
                      ` (mínimo ${presentation.minimumOrder})`}
                  </option>
                ))}
              </select>
              {product.presentations.map(
                (presentation) =>
                  presentation.minimumOrder && (
                    <p
                      class="pdp-pres-note"
                      data-presentation-note={presentation.id}
                      hidden
                    >
                      Pedido mínimo: {presentation.minimumOrder}
                    </p>
                  ),
              )}
            </div>
          )
        }

        <!-- Product Actions -->
        <div class="pdp-actions">
          <button
            class="btn btn-primary"
            type="button"
            data-action="add-to-cart"
            data-product-id={product.id}
            data-product-name={product.name}
            data-product-slug={product.slug}
            data-product-image={product.image}
            data-product-presentation={product.presentations[0]?.label || ""}
            data-presentation-id={product.presentations[0]?.id || ""}
          >
            Añadir al carrito de cotización
          </button>
          <a class="btn btn-outline" href="/cotizacion">
            Solicitar cotización
          </a>
        </div>

        <!-- Description -->
        {
          product.description && (
            <div class="pdp-info-description">
              <h3>Descripción</h3>
              <p>{product.description}</p>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- Product Details Section -->
  <section class="pdp-details">
    <div class="container">
      <!-- Related Products -->
      {
        relatedProducts && relatedProducts.length > 0 && (
          <div class="pdp-section">
            <div class="pdp-related-header">
              <span class="tag">También te puede interesar</span>
              <h2>Productos relacionados</h2>
            </div>
            <div class="pdp-carousel">
              {relatedProducts.map((item) => {
                const presentation = item.presentations[0];
                return (
                  <article class="pdp-related-card">
                    <div class="pdp-related-img">
                      {item.image ? (
                        <img src={item.image} alt={item.name} loading="lazy" />
                      ) : (
                        <div class="image-fallback" aria-hidden="true" />
                      )}
                    </div>
                    <div class="pdp-related-body">
                      <h3>{item.name}</h3>
                      <p class="pdp-related-desc">
                        {item.relationshipReason ||
                          "Producto relacionado complementario para tu industria."}
                      </p>
                    </div>
                    <div class="pdp-related-actions">
                      <a
                        class="btn btn-outline"
                        href={`/products/${item.slug}`}
                      >
                        Ver detalle
                      </a>
                      <button
                        class="btn btn-primary"
                        type="button"
                        data-action="add-to-cart"
                        data-product-id={item.id}
                        data-product-name={item.name}
                        data-product-slug={item.slug}
                        data-product-presentation={presentation?.label || ""}
                        data-presentation-id={presentation?.id || ""}
                        data-product-image={item.image}
                      >
                        Agregar
                      </button>
                    </div>
                  </article>
                );
              })}
            </div>
          </div>
        )
      }

      <!-- Ficha Técnica (Technical Data Sheet) -->
      <div class="pdp-section">
        <h2>Ficha Técnica</h2>
        <div class="pdp-ficha">
          <p class="pdp-muted">
            La ficha técnica estará disponible próximamente.
          </p>
        </div>
      </div>

      <!-- Categories -->
      {
        productCategories.length > 0 && (
          <div class="pdp-section">
            <h2>Categorías</h2>
            <ul class="pdp-categories">
              {productCategories.map((category) => (
                <li class="pdp-category">
                  <span>{category?.name ?? "Categoría"}</span>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  </section>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Presentation select handler
    const select = document.querySelector("[data-product-select]");
    const notes = document.querySelectorAll("[data-presentation-note]");
    const button = document.querySelector(
      '.product-actions [data-action="add-to-cart"]',
    );

    const updateFromSelect = () => {
      if (
        !(select instanceof HTMLSelectElement) ||
        !(button instanceof HTMLElement)
      )
        return;
      const selected = select.selectedOptions[0];
      const label = selected?.dataset.label ?? "";
      button.setAttribute("data-product-presentation", label);
      button.setAttribute("data-presentation-id", selected?.value || "");
      notes.forEach((note) => {
        const shouldHide =
          !selected ||
          note.getAttribute("data-presentation-note") !== selected.value;
        note.toggleAttribute("hidden", shouldHide);
      });
    };

    select?.addEventListener("change", updateFromSelect);
    updateFromSelect();

    // Image carousel handler
    const currentImage = document.getElementById("pdp-current-image");
    const thumbnails = document.querySelectorAll(".pdp-thumbnail");
    const prevBtn = document.getElementById("pdp-prev");
    const nextBtn = document.getElementById("pdp-next");

    if (thumbnails.length > 0) {
      let currentIndex = 0;

      const showImage = (index: number) => {
        if (!currentImage || !(currentImage instanceof HTMLImageElement))
          return;

        const thumbnail = thumbnails[index];
        if (!thumbnail) return;

        const fullSrc = thumbnail.getAttribute("data-full-src");
        const alt = thumbnail.getAttribute("alt");

        if (fullSrc) {
          currentImage.src = fullSrc;
          if (alt) currentImage.alt = alt;
        }

        // Update active thumbnail
        thumbnails.forEach((thumb, i) => {
          thumb.setAttribute("data-active", i === index ? "true" : "false");
        });

        currentIndex = index;
      };

      // Thumbnail click
      thumbnails.forEach((thumb, index) => {
        thumb.addEventListener("click", () => showImage(index));
      });

      // Navigation buttons
      prevBtn?.addEventListener("click", () => {
        const newIndex =
          (currentIndex - 1 + thumbnails.length) % thumbnails.length;
        showImage(newIndex);
      });

      nextBtn?.addEventListener("click", () => {
        const newIndex = (currentIndex + 1) % thumbnails.length;
        showImage(newIndex);
      });
    }
  });
</script>
