---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Página no encontrada | Química Industrial"
  description="La página que buscas no existe. Explora nuestro catálogo de químicos industriales y materias primas."
  noIndex={true}
>
  <section class="not-found">
    <div class="container">
      <p class="code">404</p>
      <h1 class="title">Página no encontrada</h1>
      <p class="message">
        Lo sentimos, la página que buscas no existe o fue eliminada.
      </p>
      <div class="actions">
        <a href="/" class="btn-primary">Ir al inicio</a>
        <a href="/products" class="btn-secondary">Ver catálogo</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1rem;
  }

  .container {
    max-width: 480px;
    margin: 0 auto;
  }

  .code {
    font-size: 6rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    margin: 0 0 0.5rem;
  }

  .title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 1rem;
  }

  .message {
    color: #64748b;
    font-size: 1rem;
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--color-primary);
    color: #fff;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-primary:hover {
    background: var(--color-primary-dark);
  }

  .btn-secondary {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .btn-secondary:hover {
    background: var(--color-primary);
    color: #fff;
  }
</style>
